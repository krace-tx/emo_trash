  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ffffff;
}

.nav-close { display: flex; align-items: center; }
.close-icon { font-size: 64rpx; color: #333; font-weight: 300; padding: 10rpx 20rpx 10rpx 0; }
.nav-save { display: flex; align-items: center; }
.save-text { font-size: 32rpx; color: #ff2442; font-weight: 600; padding: 20rpx 0 20rpx 20rpx; }

.main-content {
  flex: 1;
  padding-top: calc(var(--status-bar-height) + 88rpx);
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
  position: relative;
  
  .camera-badge {
    position: absolute;
    right: 50%;
    transform: translateX(80rpx);
    bottom: 120rpx;
    width: 56rpx;
    height: 56rpx;
    background-color: #fff;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
    border: 2rpx solid #f0f0f0;
    .icon { font-size: 28rpx; }
  }
  
  .tip-text {
    margin-top: 32rpx;
    font-size: 26rpx;
    color: #999;
  }
}

.form-section {
  padding: 0 40rpx;
}

.input-group {
  padding: 40rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  
  &.no-border { border-bottom: none; }
  
  .label {
    font-size: 28rpx;
    color: #666;
    margin-bottom: 20rpx;
    display: block;
    font-weight: 500;
  }
  
  .input-box {
    font-size: 34rpx;
    color: #111;
    font-weight: 600;
  }
  
  .textarea-box {
    width: 100%;
    font-size: 34rpx;
    color: #111;
    min-height: 160rpx;
    line-height: 1.6;
  }
}

.p-style { color: #ccc; font-weight: 400; }
</style>
