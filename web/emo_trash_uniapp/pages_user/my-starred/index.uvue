  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 36rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(107, 139, 164, 0.04);
  transition: transform 0.2s;
  
  &:active {
    transform: scale(0.98);
  }
  
  .post-header-row {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24rpx;
    
    .author-info {
      display: flex; 
      flex-direction: row; 
      align-items: center;
      .avatar { 
        width: 52rpx; 
        height: 52rpx; 
        border-radius: 50%; 
        margin-right: 16rpx; 
        border: 1rpx solid #F1F5F9;
      }
      .name { 
        font-size: 26rpx; 
        color: #64748B; 
        font-weight: 500; 
      }
    }
    
    .unstar-btn {
      width: 60rpx;
      height: 60rpx;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: -10rpx;
      
      .unstar-icon { 
        font-size: 36rpx; 
        color: #6B8BA4; 
      }
      &:active { opacity: 0.6; }
    }
  }
  
  .post-body {
    margin-bottom: 30rpx;
    
    .post-title { 
      display: block; 
      font-size: 32rpx; 
      font-weight: 600; 
      color: #1E293B; 
      margin-bottom: 12rpx; 
      font-family: "Source Han Serif SC", serif;
    }
    
    .post-content { 
      display: block; 
      font-size: 28rpx; 
      color: #475569; 
      line-height: 1.6; 
      overflow: hidden; 
      text-overflow: ellipsis; 
      display: -webkit-box; 
      -webkit-line-clamp: 3; 
      -webkit-box-orient: vertical; 
    }

    .image-preview {
      margin-top: 20rpx;
      position: relative;
      width: 200rpx;
      height: 200rpx;
      border-radius: 16rpx;
      overflow: hidden;
      
      .preview-img {
        width: 100%;
        height: 100%;
      }
      
      .img-count {
        position: absolute;
        inset: 0;
        background-color: rgba(0,0,0,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        .count-text { color: #FFFFFF; font-size: 24rpx; font-weight: 600; }
      }
    }
  }
  
  .post-footer {
    display: flex; 
    flex-direction: row; 
    justify-content: space-between; 
    align-items: center;
    padding-top: 24rpx;
    border-top: 1rpx solid #F1F5F9;
    
    .post-time { 
      font-size: 22rpx; 
      color: #94A3B8; 
    }
    
    .post-stats { 
      display: flex; 
      flex-direction: row; 
      gap: 24rpx; 
      
      .stat-item {
        display: flex;
        flex-direction: row;
        align-items: center;
        .stat-icon { font-size: 24rpx; margin-right: 6rpx; }
        .stat-num { font-size: 22rpx; color: #64748B; }
      }
    }
  }
}

/* 空状态样式 */
.empty-state {
  padding-top: 160rpx;
  display: flex;
  justify-content: center;
  
  .empty-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 80%;
    
    .empty-icon {
      font-size: 100rpx;
      margin-bottom: 40rpx;
      opacity: 0.8;
    }
    
    .empty-title {
      font-size: 32rpx;
      color: #334155;
      font-weight: 600;
      margin-bottom: 16rpx;
    }
    
    .empty-desc {
      font-size: 26rpx;
      color: #94A3B8;
      text-align: center;
      line-height: 1.5;
      margin-bottom: 60rpx;
    }
    
    .go-btn {
      padding: 20rpx 60rpx;
      background-color: #6B8BA4;
      border-radius: 40rpx;
      box-shadow: 0 8rpx 20rpx rgba(107, 139, 164, 0.2);
      
      .go-text {
        color: #FFFFFF;
        font-size: 28rpx;
        font-weight: 600;
      }
      
      &:active {
        opacity: 0.9;
        transform: scale(0.95);
      }
    }
  }
}

.loading-status { 
  padding: 40rpx 0 100rpx; 
  text-align: center; 
  .status-text { font-size: 24rpx; color: #CBD5E1; } 
}

