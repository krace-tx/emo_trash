<template>
  <BasePage>
    <BaseNavbar title="情绪记忆" :showBack="true" :placeholder="true" />
    
    <scroll-view 
      scroll-y 
      class="timeline-scroll" 
      @scrolltolower="loadMore"
      :refresher-enabled="true"
      :refresher-triggered="isRefreshing"
      @refresherrefresh="onRefresh"
    >
      <view class="timeline-container">
        <!-- 时间轴主体 -->
        <view class="timeline-line"></view>
        
        <view v-for="(item, index) in posts" :key="item.id" class="memory-item">
          <!-- 左侧日期标识 -->
          <view class="date-side">
            <text class="day">{{ getDay(item.created_at) }}</text>
            <text class="month">{{ getMonth(item.created_at) }}</text>
            <view class="timeline-dot"></view>
          </view>
          
          <!-- 右侧内容卡片 -->
          <view class="content-side" @click="toDetail(item.id)">
            <view class="memory-card">
              <view class="card-header">
                <view class="mood-badge" v-if="item.ai_evaluation">
                  <text class="mood-emoji">{{ getMoodEmoji(item.content) }}</text>
                </view>
                <view class="more-btn" @click.stop="showMoreAction(item, index)">
                  <text class="more-icon">•••</text>
                </view>
              </view>
              
              <view class="card-body">
                <text class="memory-title" v-if="item.title">{{ item.title }}</text>
                <text class="memory-text">{{ item.content }}</text>
                
                <view class="image-gallery" v-if="item.images.length > 0">
                  <image 
                    class="main-img" 
                    :src="item.images[0]" 
                    mode="aspectFill"
                  ></image>
                  <view class="img-badge" v-if="item.images.length > 1">
                    <text class="badge-text">+{{ item.images.length }}</text>
                  </view>
                </view>
              </view>
              
              <view class="card-footer">
                <view class="interaction">
                  <view class="stat">
                    <text class="icon">❤️</text>
                    <text class="num">{{ item.like_count }}</text>
                  </view>
                  <view class="stat">
                    <text class="icon">🐚</text>
                    <text class="num">{{ item.comment_count }}</text>
                  </view>
                </view>
                <text class="privacy-tag" v-if="item.video === 'anonymous'">匿名</text>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 空状态 -->
        <view v-if="posts.length === 0 && !isLoading" class="empty-journal">
          <view class="empty-box">
            <text class="empty-illu">✒️</text>
            <text class="empty-tip">记忆的画卷还是一片空白</text>
            <view class="write-btn" @click="toCreate">
              <text class="btn-text">开始记录</text>
            </view>
          </view>
        </view>

        <view class="loading-area" v-if="posts.length > 0">
          <text class="loading-text">{{ loadingText }}</text>
        </view>
      </view>
    </scroll-view>
  </BasePage>
</template>

<script setup>
import { ref, onMounted, computed } from 'vue'
import BasePage from '@/components/BasePage.uvue'
import BaseNavbar from '@/components/BaseNavbar.uvue'
import { listMyPosts, deletePost, type PostInfo } from '@/api/post'

const posts = ref<PostInfo[]>([])
const cursor = ref('')
const hasMore = ref(true)
const isLoading = ref(false)
const isRefreshing = ref(false)

const loadingText = computed((): string => {
  if (isLoading.value) return '正在翻阅时光...'
  if (!hasMore.value) return '所有的记忆都在这里了'
  return '向上滑动加载更多'
})

onMounted(() => {
  fetchPosts(true)
})

async function fetchPosts(isFirst: boolean = false) {
  if (isLoading.value) return
  if (!isFirst && !hasMore.value) return
  
  isLoading.value = true
  if (isFirst) {
    cursor.value = ''
    hasMore.value = true
  }
  
  try {
    const res = await listMyPosts({
      cursor: cursor.value,
      page_size: 10
    })
    
    if (isFirst) {
      posts.value = res.list
    } else {
      posts.value = posts.value.concat(res.list)
    }
    
    cursor.value = res.next_cursor
    hasMore.value = res.has_more
  } catch (e) {
    uni.showToast({ title: '暂时无法读取记忆', icon: 'none' })
  } finally {
    isLoading.value = false
    isRefreshing.value = false
  }
}

async function onRefresh() {
  isRefreshing.value = true
  await fetchPosts(true)
}

function showMoreAction(item: PostInfo, index: number) {
  uni.showActionSheet({
    itemList: ['编辑内容', '彻底丢弃'],
    itemColor: '#334155',
    success: async (res) => {
      if (res.tapIndex === 1) {
        handleDelete(item.id, index)
      }
    }
  })
}

async function handleDelete(id: string, index: number) {
  uni.showModal({
    title: '彻底丢弃这段记忆？',
    content: '删除后将无法找回。',
    confirmText: '确定',
    confirmColor: '#EF4444',
    success: async (res) => {
      if (res.confirm) {
        uni.showLoading({ title: '正在清理...' })
        try {
          const success = await deletePost(id)
          if (success) {
            posts.value.splice(index, 1)
            uni.showToast({ title: '已消失', icon: 'none' })
            uni.$emit('refreshPosts')
          }
        } catch (e) {
          uni.showToast({ title: '操作失败', icon: 'none' })
        } finally {
          uni.hideLoading()
        }
      }
    }
  })
}

function loadMore() {
  fetchPosts()
}

function toDetail(id: string) {
  uni.navigateTo({ url: `/pages/post/detail/index?id=${id}` })
}

function toCreate() {
  uni.navigateTo({ url: '/pages/post/create/index' })
}

// 辅助方法：获取日期
function getDay(ts: number): string {
  const d = new Date(ts * 1000)
  return d.getDate().toString().padStart(2, '0')
}

// 辅助方法：获取月份（简写）
function getMonth(ts: number): string {
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
  const d = new Date(ts * 1000)
  return months[d.getMonth()]
}

// 辅助方法：根据内容模拟一个心情图标（实际中可从后端获取）
function getMoodEmoji(content: string): string {
  const emojis = ['🍃', '☁️', '🌊', '🌙', '☕', '✨']
  return emojis[Math.abs(content.length % emojis.length)]
}

function formatTime(timestamp: number): string {
  const date = new Date(timestamp * 1000)
  return `${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}`
}
</script>

