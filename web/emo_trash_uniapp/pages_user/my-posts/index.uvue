      width: 100%;
      height: 300rpx;
      border-radius: 20rpx;
      overflow: hidden;
      
      .main-img { width: 100%; height: 100%; }
      .img-badge {
        position: absolute; right: 20rpx; bottom: 20rpx;
        background-color: rgba(0,0,0,0.4);
