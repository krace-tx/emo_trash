    padding: 0 32rpx;
    background-color: #E2E8F0;
    color: #94A3B8;
    font-size: 24rpx;
    border-radius: 12rpx;
    margin: 0;
    border: none;
    font-weight: 600;
    
    &::after { border: none; }
    
    &.active {
      background-color: #86929B;
      color: #FFFFFF;
    }
  }
}

