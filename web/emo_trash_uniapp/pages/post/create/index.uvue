  padding: 100rpx 32rpx 20rpx;
  background-color: rgba(253, 250, 243, 0.8);
  backdrop-filter: blur(4px);
  
  .back-arrow {
    font-size: 44rpx;
    color: #475569;
    font-weight: 300;
  }
  
  .nav-middle {
    flex: 1;
    display: flex;
    justify-content: center;
    .nav-title-img {
      width: 240rpx;
      height: 60rpx;
    }
  }
  
  .publish-btn {
    height: 56rpx;
