}

/* 进度环模拟 */
.upload-progress {
  position: absolute;
  inset: 0;
  background-color: rgba(255,255,255,0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  .progress-ring {
    width: 40rpx;
    height: 40rpx;
    border: 3rpx solid #86929B;
    border-top-color: transparent;
    border-radius: 50%;
    animation: rotate 1s linear infinite;
  }
}

@keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

/* 底部快捷工具 */
.bottom-toolbar {
  background-color: #FDFAF3;
  padding: 20rpx 40rpx 60rpx;
  border-top: 1rpx solid #F1F5F9;
  
  .toolbar-left {
    display: flex;
    flex-direction: row;
    align-items: center;
    
    .tool-btn {
      padding: 10rpx 20rpx;
      margin-right: 10rpx;
      .tool-icon { font-size: 40rpx; }
      &:active { opacity: 0.6; }
    }
    
    .divider {
      width: 1rpx;
      height: 40rpx;
      background-color: #E2E8F0;
      margin: 0 20rpx;
    }
    
    .anonymous-box {
      flex: 1;
      display: flex;
      flex-direction: row;
