  padding: 40rpx 40rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  position: relative;
  
  .user-avatar {
    width: 64rpx;
    height: 64rpx;
    border-radius: 50%;
    border: 1rpx solid #E2E8F0;
    background-color: #FFF;
  }
  
  .user-id {
    margin-left: 16rpx;
    font-size: 24rpx;
    color: #64748B;
    font-weight: 500;
    letter-spacing: 1rpx;
  }
  
  /* 装饰线条 */
  .deco-lines {
    position: absolute;
    right: 40rpx;
    top: 20rpx;
    width: 100rpx;
    height: 100rpx;
    border-right: 1rpx solid #E2E8F0;
    border-top: 1rpx solid #E2E8F0;
    opacity: 0.5;
  }
