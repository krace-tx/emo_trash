<template>
  <view class="publish-page">
    <!-- ① 艺术化顶部导航栏 -->
    <view class="custom-nav">
      <view class="nav-left" @click="goBack">
        <text class="back-arrow">←</text>
      </view>
      <view class="nav-middle">
        <image src="/static/post/title.png" mode="aspectFit" class="nav-title-img"></image>
      </view>
      <view class="nav-right">
        <button 
          class="publish-btn" 
          :class="{ active: canPublish }" 
          :disabled="!canPublish"
          @click="submitPost"
        >
          Publish
        </button>
      </view>
    </view>

    <scroll-view scroll-y class="editor-scroll">
      <!-- ② 用户信息区 (着陆感) -->
      <view class="user-header">
        <image class="user-avatar" :src="userStore.userInfo?.avatar || '/static/logo.png'" mode="aspectFill"></image>
        <text class="user-id">@{{ userStore.userInfo?.nickname || 'MindTraveler' }}</text>
        <!-- 背景点缀线条可通过 CSS 或背景图模拟 -->
        <view class="deco-lines"></view>
      </view>

      <view class="editor-container">
        <!-- ③ 标题输入 (细边框) -->
        <view class="title-input-wrapper">
          <input 
            class="title-input" 
            v-model="formData.title" 
            placeholder="Title..." 
            placeholder-class="ph-color"
            maxlength="30"
          />
        </view>
        
        <!-- 正文输入 -->
        <textarea 
          class="content-input" 
          v-model="formData.content" 
          placeholder="Write down the thoughts you don't want to take away..." 
          placeholder-class="ph-color"
          :maxlength="-1" 
          auto-height
          :focus="true"
        ></textarea>

        <!-- 错误提示 -->
        <view class="error-tip" :style="{ opacity: showEmptyTip ? 1 : 0 }">
          <text class="error-text">* 内容不能为空 / Content cannot be empty</text>
        </view>

        <!-- ④ 九宫格媒体区 -->
        <view class="media-section">
          <view class="section-title">Attachments</view>
          <view class="image-grid">
            <view class="image-box upload-box" @click="chooseImage" v-if="localImages.length < 9">
              <text class="plus-icon">+</text>
            </view>
            <view class="image-box" v-for="(img, index) in localImages" :key="index">
              <image :src="img" mode="aspectFill" class="preview-img" @click="previewImage(index)"></image>
              <view class="delete-btn" @click.stop="removeImage(index)">✕</view>
              <!-- 模拟上传进度环 (仅为演示) -->
              <view class="upload-progress" v-if="index === 0 && isPublishing">
                <view class="progress-ring"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- ⑤ 底部快捷工具栏 -->
    <view class="bottom-toolbar">
      <view class="toolbar-left">
        <view class="tool-btn" @click="chooseImageFrom('camera')">
          <text class="tool-icon">📷</text>
        </view>
        <view class="tool-btn" @click="chooseImageFrom('album')">
          <text class="tool-icon">🖼️</text>
        </view>
        <view class="divider"></view>
        <view class="anonymous-box">
          <text class="anon-label">Post Anonymously</text>
          <switch 
            :checked="formData.is_anonymous" 
            @change="onAnonymousChange" 
            color="#86929B"
            style="transform: scale(0.7);"
          />
        </view>
      </view>
    </view>
  </view>
</template>

<script setup>
import { ref, computed } from 'vue'
import { createPost } from '@/api/post'
import { useUserStore } from '@/stores/user'

const userStore = useUserStore()
const isPublishing = ref(false)

// 表单数据
const formData = ref({
  title: '',
  content: '',
  images: [] as string[],
  is_anonymous: false
})

// 本地预览图
const localImages = ref<string[]>([])

// 是否显示空内容提示
const showEmptyTip = computed((): boolean => {
  return formData.value.content.trim().length === 0 && formData.value.title.length > 0
})

// 是否可以发布
const canPublish = computed((): boolean => {
  return formData.value.content.trim().length > 0
})

function goBack() {
  uni.navigateBack()
}

function onAnonymousChange(e: any) {
  formData.value.is_anonymous = (e.detail.value as boolean)
}

function chooseImage() {
  chooseImageFrom('all')
}

function chooseImageFrom(type: string) {
  let sourceType = ['album', 'camera']
  if (type === 'camera') sourceType = ['camera']
  if (type === 'album') sourceType = ['album']

  uni.chooseImage({
    count: 9 - localImages.value.length,
    sizeType: ['compressed'],
    sourceType: sourceType,
    success: (res) => {
      if (res.tempFilePaths != null && res.tempFilePaths.length > 0) {
        localImages.value = localImages.value.concat(res.tempFilePaths)
      }
    }
  })
}

function previewImage(current: number) {
  uni.previewImage({
    urls: localImages.value,
    current: current
  })
}

function removeImage(index: number) {
  localImages.value.splice(index, 1)
}

async function submitPost() {
  if (!canPublish.value) return
  
  isPublishing.value = true
  uni.showLoading({ title: 'Packing emotions...' })

  try {
    await createPost({
      title: formData.value.title,
      content: formData.value.content,
      images: [] as string[], 
      is_anonymous: formData.value.is_anonymous
    })

    uni.hideLoading()
    uni.showToast({ title: 'Emotions dropped.', icon: 'success' })
    uni.$emit('refreshPosts')
    
    setTimeout(() => {
      uni.navigateBack()
    }, 1200)

  } catch (e) {
    isPublishing.value = false
    uni.hideLoading()
    uni.showToast({ title: 'Failed to drop', icon: 'none' })
  }
}
</script>

<style lang="scss" scoped>
