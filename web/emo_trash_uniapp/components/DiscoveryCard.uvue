<template>
  <view class="card-container" @click="onClick">
    <!-- 上层主内容：左文右图 -->
    <view class="card-main">
      <view class="text-content">
        <text class="title">{{ post.title || '无题' }}</text>
        <text class="excerpt">{{ post.content || '把不想带走的情绪丢在这里...' }}</text>
      </view>
      
      <image 
        v-if="post.images && post.images.length > 0" 
        class="cover-image" 
        :src="post.images[0]" 
        mode="aspectFill"
      ></image>
    </view>

    <!-- 下层互动区 -->
    <view class="card-footer">
      <view class="footer-left">
        <view class="icon-bubble">
          <view class="bubble-rect"></view>
          <view class="bubble-tip"></view>
        </view>
        <text class="likes-text">{{ post.like_count || 0 }}人也这样</text>
      </view>
      
      <view class="footer-right">
        <text class="time-text">{{ formatTime(post.created_at) }}</text>
        <view class="more-btn">
          <text class="icon-more">···</text>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup>
const props = defineProps({
  post: {
    type: Object,
    required: true
  }
})

const emit = defineEmits(['click'])

function onClick() {
  emit('click', props.post.id)
}

function formatTime(timestamp: number): string {
  // 简易时间格式化，实际可接入更复杂的工具函数
  const now = Date.now()
  const diff = (now - timestamp) / 1000
  if (diff < 60) return '刚刚'
  if (diff < 3600) return Math.floor(diff / 60) + '分钟前'
  if (diff < 86400) return Math.floor(diff / 3600) + '小时前'
  return '1天前'
}
</script>

