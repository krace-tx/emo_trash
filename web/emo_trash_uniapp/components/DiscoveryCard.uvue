  line-height: 1.4;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.excerpt {
  font-size: 26rpx;
  color: #707070; /* 中灰色 */
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.cover-image {
  width: 200rpx;
  height: 130rpx;
  border-radius: 16rpx;
  background-color: #F8F9F9;
  flex-shrink: 0;
}

.card-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.footer-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  color: #6B8BA4;
}

.icon-bubble {
  width: 24rpx;
  height: 20rpx;
  margin-right: 10rpx;
  position: relative;
  .bubble-rect {
    width: 100%;
    height: 16rpx;
    border: 2rpx solid #6B8BA4;
    border-radius: 4rpx;
  }
  .bubble-tip {
    position: absolute;
    bottom: -2rpx;
    left: 4rpx;
    width: 6rpx;
    height: 6rpx;
    border-left: 2rpx solid #6B8BA4;
    border-bottom: 2rpx solid #6B8BA4;
    background-color: #FFF;
    transform: rotate(45deg);
  }
}

