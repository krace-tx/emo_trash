syntax = "v1"

info (
	title:   "Gateway Service API"
	author:  "krace"
	email:   "qilinhu009@gmail.com"
	version: "v1"
)

import "sso.api"
import "post.api"

// 公共服务 - 无需授权
@server (
	group:   sso
	prefix:  /sso/v1
	timeout: 10s
)
service gateway {
	@handler SendEmailCode
	post /auth/email/code (SendEmailCodeReq) returns (CommonResp)

	@handler Register
	post /auth/register (RegisterReq) returns (CommonResp)

	@handler Login
	post /auth/login (LoginReq) returns (CommonResp)

	@handler ResetPassword
	post /auth/password/reset (ResetPasswordReq) returns (CommonResp)

	@handler RefreshToken
	post /auth/token/refresh (RefreshTokenReq) returns (CommonResp)

	@handler LoginByThirdParty
	post /auth/thirdparty/login (LoginByThirdPartyReq) returns (CommonResp)

	@handler GenerateQrcode
	get /auth/qrcode/generate (GenerateQrcodeReq) returns (CommonResp)

	@handler CheckQrcodeStatus
	get /auth/qrcode/status (CheckQrcodeStatusReq) returns (CommonResp)
}

// 授权服务 - 需要自定义 Auth 中间件
@server (
	group:      sso
	prefix:     /sso/v1
	middleware: Auth
	timeout:    10s
)
service gateway {
	@handler ChangePassword
	post /auth/password/change (ChangePasswordReq) returns (CommonResp)

	@handler VerifyToken
	post /auth/token/verify (VerifyReq) returns (CommonResp)

	@handler Logout
	post /auth/logout (LogoutReq) returns (CommonResp)

	@handler GetUserInfo
	get /user/info (GetUserInfoReq) returns (CommonResp)

	@handler UpdateUserInfo
	post /user/info/update (UpdateUserInfoReq) returns (CommonResp)

	@handler GetUserStats
	get /user/stats (GetUserStatsReq) returns (CommonResp)

	@handler GetComfortMessage
	get /common/comfort (GetComfortMessageReq) returns (CommonResp)

	@handler ConfirmQrcodeLogin
	post /auth/qrcode/confirm (ConfirmQrcodeLoginReq) returns (CommonResp)

	@handler UploadMedia
	post /common/upload (UploadMediaReq) returns (CommonResp)
}

@server (
	group:      post
	prefix:     /post/v1
	middleware: Auth
	timeout:    10s
)
service gateway {
	@handler CreatePost
	post /create (CreatePostReq) returns (CommonResp)

	@handler UpdatePost
	post /update (UpdatePostReq) returns (CommonResp)

	@handler DeletePost
	post /delete (DeletePostReq) returns (CommonResp)

	@handler GetPostDetail
	get /detail (GetPostDetailReq) returns (CommonResp)

	@handler ListPosts
	get /list (ListPostsReq) returns (CommonResp)

	@handler LikePost
	post /like (LikePostReq) returns (CommonResp)

	@handler StarPost
	post /star (StarPostReq) returns (CommonResp)

	@handler ListMyPosts
	get /list/my (ListMyPostsReq) returns (CommonResp)

	@handler ListStarredPosts
	get /list/starred (ListStarredPostsReq) returns (CommonResp)

	@handler CreateComment
	post /comment/create (CreateCommentReq) returns (CommonResp)

	@handler DeleteComment
	post /comment/delete (DeleteCommentReq) returns (CommonResp)

	@handler ListComments
	get /comment/list (ListCommentsReq) returns (CommonResp)
}

